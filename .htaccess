Options -Indexes

<IfModule mod_authz_core.c>
  <FilesMatch "^(config\.php|config\.sample\.php|.*\.xlsx|.*\.sqlite3|.*\.db)$">
    Require all denied
  </FilesMatch>
  RedirectMatch 403 ^/(src|data|tests|scripts|app)(/|$)
</IfModule>

<IfModule !mod_authz_core.c>
  <FilesMatch "^(config\.php|config\.sample\.php|.*\.xlsx|.*\.sqlite3|.*\.db)$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>
