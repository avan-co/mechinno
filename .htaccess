Options -Indexes
DirectoryIndex index.php

<IfModule mod_authz_core.c>
  <FilesMatch "^(config\.php|config\.sample\.php|.*\.(xlsx|sqlite3|db|sql|log|bak|env))$">
    Require all denied
  </FilesMatch>
  RedirectMatch 403 ^/(src|data|tests|scripts|tools|app)(/|$)
</IfModule>

<IfModule !mod_authz_core.c>
  <FilesMatch "^(config\.php|config\.sample\.php|.*\.(xlsx|sqlite3|db|sql|log|bak|env))$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>
